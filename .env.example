# SocialOS runs locally with zero API keys by default.
# Use bash scripts/provider_doctor.sh after editing this file to see what each key unlocks.

# Core app
# Optional. Default API port for the local loopback-only server.
SOCIALOS_API_PORT=8787
# Optional. Default web port for the local loopback-only app.
SOCIALOS_WEB_PORT=4173
# Optional. quickstart manages this automatically; leave as demo unless you know you want local.
SOCIALOS_PROFILE=demo
# Usually managed by scripts/quickstart.sh via .env.local.
# SOCIALOS_DB_PATH=
# Optional. Keeps publishing in a safe rehearsal mode by default.
PUBLISH_MODE=dry-run
# Optional. Keeps the hackathon overlays enabled for the public proof routes.
HACKATHON_MODE=all-bounties

# Embeddings and retrieval
# Optional. auto = use OpenAI when a key exists, otherwise fall back to local embeddings.
EMBEDDINGS_PROVIDER=auto
# Optional. Improves retrieval quality and also unlocks voice transcription support.
OPENAI_API_KEY=
# Optional. Used only when OPENAI_API_KEY is set and embeddings resolve to OpenAI.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional. Used only when OPENAI_API_KEY is set for automatic voice-note transcription.
OPENAI_AUDIO_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# Optional local fallback model. SocialOS still works without any cloud key.
LOCAL_EMBEDDING_MODEL=strong
# Optional retrieval toggle. Leave off unless you are benchmarking or comparing retrieval behavior.
DUAL_INDEX=0

# Z.AI / GLM
# Optional. Unlocks live GLM-backed summaries and generation for the Z.AI bounty route.
GLM_API_KEY=
# Optional. Live model used by the Z.AI integration.
GLM_MODEL_ID=glm-4.7

# FLock / AI Agents for Good
# Optional. Unlocks live SDG triage and next-step guidance for the impact workflow.
FLOCK_API_KEY=
# Optional. Open-source-model-backed FLock route used for AI Agents for Good.
FLOCK_MODEL_ID=qwen3-30b-a3b-instruct-2507

# Telegram volunteer channel
# Optional. Enables the Telegram send path for AI Agents for Good follow-through.
TELEGRAM_BOT_TOKEN=
# Optional. Enables webhook proof capture in addition to send-only channel proof.
TELEGRAM_WEBHOOK_SECRET=
# Optional. Required together with TELEGRAM_BOT_TOKEN for the default Telegram target.
TELEGRAM_DEFAULT_CHAT_ID=
# Optional display metadata for docs and public proof output.
TELEGRAM_BOT_USERNAME=

# Minimal useful live setups
# OpenAI only:
# OPENAI_API_KEY=...
#
# Z.AI only:
# GLM_API_KEY=...
#
# FLock only:
# FLOCK_API_KEY=...
#
# Full live bounty stack:
# OPENAI_API_KEY=...
# GLM_API_KEY=...
# FLOCK_API_KEY=...
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_DEFAULT_CHAT_ID=...
# TELEGRAM_WEBHOOK_SECRET=...
